# --- Required ---
# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
# Telegram numeric user id of the admin (get it from /whoami or @userinfobot).
# This account is auto-approved and is the sole approver of other users.
ADMIN_TELEGRAM_ID=123456789

# --- Optional (defaults shown) ---
ANTHROPIC_MODEL=claude-opus-4-8
# Speech-to-text for voice messages (OpenAI audio API). Without a key, voice
# notes are ignored. https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional "humorizer": after Anthropic answers, a cheap OpenAI model rewrites
# the TONE of plain-chat replies to be funnier. Tone only — facts/numbers/links
# are preserved, and factual/tool answers (expenses, surf, web search,
# reminders) are never touched. Needs OPENAI_API_KEY. Off by default.
ENABLE_HUMOR=false
OPENAI_HUMOR_MODEL=gpt-5-mini
DEFAULT_CURRENCY=EUR
DATABASE_PATH=./data/bot.sqlite
LOG_LEVEL=info
# How long a pending (un-confirmed) expense preview stays valid, in minutes.
PENDING_TTL_MINUTES=30
# How many recent conversation turns per chat to feed the model as context.
CONVERSATION_HISTORY_LIMIT=20
# Enable Claude web_search server tool (requires outbound internet on the host).
ENABLE_WEB_SEARCH=true
# Enable the surf_forecast tool (Open-Meteo marine/weather API; no key needed,
# but the host must allow outbound HTTPS to *.open-meteo.com).
ENABLE_SURF=true
# Fallback IANA timezone for reminders when a chat hasn't set one yet
# (the bot asks each chat for its timezone the first time a reminder is created).
DEFAULT_TIMEZONE=UTC
