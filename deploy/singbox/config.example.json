{
  "//": "DRAFT TEMPLATE. Copy to config.json and fill the vless-out outbound from your vless:// link. Schema targets sing-box v1.11.x (pinned in docker-compose). The example outbound below is for VLESS + REALITY (xtls-rprx-vision) — the most common modern setup; if your link uses plain TLS + ws/grpc, the tls/transport fields differ.",
  "log": { "level": "warn", "timestamp": true },
  "dns": {
    "servers": [
      { "tag": "remote", "address": "https://1.1.1.1/dns-query", "detour": "vless-out" }
    ],
    "final": "remote",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sb-tun0",
      "inet4_address": "172.18.0.1/30",
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "sniff": true
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "vless-out",
      "server": "REPLACE_ME_SERVER",
      "server_port": 443,
      "uuid": "REPLACE_ME_UUID",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "REPLACE_ME_SNI",
        "utls": { "enabled": true, "fingerprint": "chrome" },
        "reality": {
          "enabled": true,
          "public_key": "REPLACE_ME_PUBLIC_KEY",
          "short_id": "REPLACE_ME_SHORT_ID"
        }
      }
    },
    { "type": "direct", "tag": "direct" },
    { "type": "dns", "tag": "dns-out" }
  ],
  "route": {
    "rules": [
      { "protocol": "dns", "outbound": "dns-out" },
      { "ip_is_private": true, "outbound": "direct" }
    ],
    "auto_detect_interface": true,
    "final": "vless-out"
  }
}
