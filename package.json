{
  "name": "secretary-bot",
  "version": "0.1.0",
  "description": "Telegram expense-tracking chatbot that records group expenses to Splid (and other pluggable providers), with a conversational LLM mode and admin authorization.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/db/migrations && cp -R src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "grammy": "^1.39.1",
    "pino": "^10.0.0",
    "splid-js": "^1.2.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.9",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
